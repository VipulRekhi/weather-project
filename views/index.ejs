<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Weatherly</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/styles/main.css">
</head>
<body class="page page--index">
    <main class="landing">
        <article class="landing__card">
            <div class="landing__brand" aria-hidden="true">
                <svg class="landing__logo" viewBox="0 0 48 48" fill="none">
                    <circle cx="24" cy="24" r="10" fill="#FBBF24"/>
                    <path d="M14 30c0-5.5 4.5-10 10-10s10 4.5 10 10" fill="#E0F2FE" stroke="#93C5FD" stroke-width="1.5"/>
                    <path d="M10 32c2-4 6-6 10-6h8c4 0 8 2 10 6" fill="#fff" opacity="0.9"/>
                </svg>
            </div>
            <h1 class="landing__title">Weatherly</h1>
            <p class="landing__subtitle">Search any city to get current weather conditions</p>

            <form action="/result" method="post" class="search-form">
                <div class="search-form__field">
                    <span class="search-form__icon" aria-hidden="true">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                            <circle cx="12" cy="10" r="3"></circle>
                        </svg>
                    </span>
                    <input
                        type="text"
                        name="place"
                        class="search-form__input"
                        placeholder="Search for a city..."
                        autocomplete="off"
                        required
                    >
                </div>
                <button type="submit" class="search-form__submit">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <circle cx="11" cy="11" r="8"></circle>
                        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                    </svg>
                    Search Weather
                </button>
            </form>

            <% if(locals.error){%>
            <p class="error-message" role="alert"><%= error %></p>
            <% } %>
        </article>
    </main>
</body>
</html>
